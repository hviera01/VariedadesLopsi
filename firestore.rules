rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // NOTA DE SEGURIDAD: esta app no usa Firebase Authentication (login propio
    // vía Firestore), por lo que request.auth siempre es null. Estas reglas son
    // permisivas a propósito para que la app funcione.

    match /usuarios/{idUsuario} {
      allow read, write: if true;
    }

    match /categorias/{idCategoria} {
      allow read, write: if true;
    }

    match /productos/{idProducto} {
      allow read, write: if true;

      match /historial/{idHistorial} {
        allow read, write: if true;
      }

      match /historialPreciosCompra/{idHistorial} {
        allow read, write: if true;
      }

      match /historialVentas/{idHistorial} {
        allow read, write: if true;
      }

      match /lotes/{idLote} {
        allow read, write: if true;
      }
    }

    match /configuracion/{idDocumento} {
      allow read, write: if true;
    }

    match /colores/{idColor} {
      allow read, write: if true;
    }

    match /clientes/{idCliente} {
      allow read, write: if true;
    }

    match /proveedores/{idProveedor} {
      allow read, write: if true;
    }

    match /ventasCredito/{idCredito} {
      allow read, write: if true;

      match /abonos/{idAbono} {
        allow read, write: if true;
      }
    }

    match /comprasCredito/{idCompra} {
      allow read, write: if true;

      match /abonosCompra/{idAbono} {
        allow read, write: if true;
      }
    }

    match /compras/{idCompra} {
      allow read, write: if true;

      match /detalle/{idItem} {
        allow read, write: if true;
      }
    }

    match /ventas/{idVenta} {
      allow read, write: if true;

      match /detalle/{idItem} {
        allow read, write: if true;
      }
    }

    match /ventasEnEspera/{idSesion} {
      allow read, write: if true;
    }

    // Sesiones cortas de escaneo remoto: la PC crea el código, el celular
    // (sin necesidad de iniciar sesión) manda ahí los códigos que escanea.
    match /escaneosRemotos/{idSesion} {
      allow read, write: if true;

      match /eventos/{idEvento} {
        allow read, write: if true;
      }
    }

    match /contadores/{idContador} {
      allow read, write: if true;
    }

    match /cajaEstado/{idDocumento} {
      allow read, write: if true;
    }

    // Latido de presencia de la PC principal (ver
    // PresenciaImpresionRepository): la PC escribe acá cada 25s mientras
    // está abierta, y el celular lo lee antes de pedir impresión en vivo.
    match /presenciaImpresion/{idDocumento} {
      allow read, write: if true;
    }

    match /cierresCaja/{idCierre} {
      allow read, write: if true;
    }

    match /egresos/{idEgreso} {
      allow read, write: if true;
    }

    match /celulares/{idCelular} {
      allow read, write: if true;

      match /historial/{idHistorial} {
        allow read, write: if true;
      }
    }

    match /puntosClientes/{idPuntos} {
      allow read, write: if true;
    }

    // Las reglas anidadas de arriba (ventasCredito/{id}/abonos y
    // comprasCredito/{id}/abonosCompra) solo cubren lecturas bajo un padre
    // conocido. Las consultas collectionGroup (usadas para sumar abonos por
    // rango de fecha en Cierre de Caja / Libro Financiero) necesitan además
    // un match recursivo a nivel raíz para el grupo de colección.
    match /{path=**}/abonos/{idAbono} {
      allow read, write: if true;
    }

    match /{path=**}/abonosCompra/{idAbono} {
      allow read, write: if true;
    }

    match /{path=**}/detalle/{idItem} {
      allow read, write: if true;
    }
  }
}
